MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=aiintern_db
JWT_SECRET_KEY=your-strong-secret-key-min-32-chars
FLASK_PORT=5000
FLASK_DEBUG=True

# LLM provider: ollama | groq
LLM_PROVIDER=groq
LLM_MAX_RETRIES=1

# Groq cloud API (get key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=30

# ─── Job Scraper API Keys ─────────────────────────────────────────
JSEARCH_API_KEY=your-jsearch-api-key
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
SCRAPER_INTERVAL_HOURS=6

# ─── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email OTP (SMTP) ────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
